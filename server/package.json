{
  "name": "pixhood-server",
  "version": "1.0.0",
  "description": "Pixhood backend — Node.js + Redis + native WebSockets",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "vitest run",
    "predeploy": "mkdir -p shared && cp -r ../shared/ws-types.js shared/",
    "deploy": "fly deploy --remote-only"
  },
  "dependencies": {
    "redis": "^4.6.13",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
